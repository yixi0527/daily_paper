APP_NAME=Daily Paper Tracker
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:5173
FRONTEND_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/daily_paper
SYNC_TIMEZONE=Asia/Shanghai
SYNC_HOUR=22
SYNC_MINUTE=0
SYNC_LOOKBACK_DAYS=60
SYNC_MAX_PAGES=5
SYNC_HTTP_TIMEOUT=30
SYNC_RETRY_ATTEMPTS=4
SYNC_MIN_INTERVAL_SECONDS=1.5
HTTP_USER_AGENT=DailyPaperTracker/1.0 (+https://github.com/your-org/daily_paper)
CROSSREF_MAILTO=research@example.com
RUN_SCHEDULER=false
EXPORT_STATIC_DATA_DIR=apps/web/public/data
VITE_APP_MODE=live
VITE_API_BASE_URL=http://localhost:8000/api
VITE_STATIC_DATA_BASE=/data
VITE_GITHUB_PAGES_BASE=/

